# NitroID credentials for OIDC authentication
# These environment variables are used by matrix-locust for real OIDC login
# instead of storing passwords in plain text files

# Your NitroID username (email address)
NITROID_USERNAME=your_username_here@company.com

# Your NitroID password
NITROID_PASSWORD=your_password_here

# Example usage:
# 1. Copy this file to .env and fill in your credentials
# 2. Source the environment variables: source .env
# 3. Run matrix-locust tests with OIDC authentication
#
# Security note: Never commit .env files with real credentials to version control